---
import Layout from '@/layouts/Layout.astro';
import ThePerformer from '@/components/performer/index.astro';
import { PERFORMERS } from '@/utils/const';
import { toKebabCase } from '@/utils/functions';
import type { InferGetStaticParamsType, GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  return PERFORMERS.map(([performer, baseOfURL, arrayNameOfS0ngs]) => ({
    params: { performer: toKebabCase(performer) },
    props: { arrayNameOfS0ngs, originalPerformerName: performer, baseOfURL }
  }));
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;

const { performer } = Astro.params as Params;
const { arrayNameOfS0ngs, originalPerformerName, baseOfURL } = Astro.props;

const getURL = (path: string) => `${baseOfURL}${path}`;
const logoSrc = getURL('/logo.webp');
const [poster1, poster2, poster3, poster4] = Array.from(
  { length: 4 },
  (_, i) => `url(${getURL(`/n${i + 1}.avif`)})`
);
---

<Layout title={performer}>
  <ThePerformer
    logoSrc={logoSrc}
    poster1={poster1}
    poster2={poster2}
    poster3={poster3}
    poster4={poster4}
    performer={originalPerformerName}
    arrayNameOfS0ngs={arrayNameOfS0ngs}
    baseOfURL={baseOfURL}
  />
</Layout>
